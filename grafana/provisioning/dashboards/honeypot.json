          "format": "table",
          "rawSql": "SELECT\n  timestamp AS \"Time\",\n  source_ip::text AS \"Source IP\",\n  service AS \"Service\",\n  event_type AS \"Event Type\",\n  COALESCE(username, '') AS \"Username\"\nFROM events\nWHERE $__timeFilter(timestamp)\nORDER BY timestamp DESC\nLIMIT 100",
